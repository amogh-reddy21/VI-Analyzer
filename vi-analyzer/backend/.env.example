# VI Analyzer — environment variable reference
# Copy this file to vi-analyzer/backend/.env and fill in real values.
# None of these are required for local dev; the defaults shown here are used
# automatically when the variable is absent from the environment.

# Flask
FLASK_DEBUG=false                          # set true for local dev hot-reload
SECRET_KEY=dev-secret-change-in-prod       # CHANGE THIS in any deployed environment

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# yfinance / price data defaults
DEFAULT_PERIOD=1y                          # default lookback: 1mo 3mo 6mo 1y 2y 5y
DEFAULT_INTERVAL=1d                        # price interval: 1d 1wk 1mo
